# Backend
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
# Optional comma-separated extra frontend origins. Vercel preview URLs are handled dynamically.
ALLOWED_ORIGINS=
# Optional comma-separated Vercel project slugs allowed for production and preview deployments.
VERCEL_ALLOWED_PROJECTS=strategy-hub-interview,strategy-hub-interview-app
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
GOOGLE_GENAI_API_KEY=replace-with-your-google-genai-api-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_VERIFY_MODELS=false
GEMINI_STAGE_CONCURRENCY=2

# Password reset email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-your-email-app-password
EMAIL_FROM=Strategy Hub <your-email@example.com>
PASSWORD_RESET_TOKEN_MINUTES=15

# Frontend / Next.js
BACKEND_URL=http://127.0.0.1:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
